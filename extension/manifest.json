{
  "manifest_version": 3,
  "name": "Preciprocal",
  "version": "1.4.0",
  "description": "AI career assistant: auto-apply on LinkedIn, Indeed, Workday & 12 more job boards, plus cover letters & interview prep",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "externally_connectable": {
    "matches": [
      "https://preciprocal.com/*",
      "https://www.preciprocal.com/*",
      "http://localhost:3000/*"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://preciprocal.com/*"
      ],
      "js": ["auth-receiver.js", "localhost-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["banner.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.workday.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.myworkday.com/*",
        "https://*.indeed.com/*",
        "https://*.ashbyhq.com/*",
        "https://*.icims.com/*",
        "https://*.jobvite.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.taleo.net/*",
        "https://*.successfactors.com/*",
        "https://*.bamboohr.com/*",
        "https://*.recruitee.com/*",
        "https://*.applytojob.com/*",
        "https://*.wellfound.com/*",
        "https://*.angel.co/*",
        "https://*.rippling.com/*",
        "https://*.pinpointhq.com/*",
        "https://*.dover.com/*",
        "https://*.workable.com/*",
        "https://*.breezy.hr/*",
        "https://*.jazz.co/*",
        "https://*.jazhr.com/*",
        "https://*.polymer.co/*",
        "https://*.hiring.com/*",
        "https://*.comeet.com/*",
        "https://*.teamtailor.com/*",
        "https://*.personio.de/*",
        "https://*.personio.com/*",
        "https://*.hi.com/*",
        "https://*.jobscore.com/*",
        "https://*.paylocity.com/*",
        "https://*.paycom.com/*",
        "https://*.adp.com/*",
        "https://*.ultipro.com/*",
        "https://*.dayforce.com/*"
      ],
      "js": ["external-apply.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon16.png",
        "icons/icon48.png",
        "icons/icon128.png",
        "external-apply.js",
        "content.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}